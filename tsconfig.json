{
  "compilerOptions": {
    "target":           "ES2022",
    "module":           "Node16",
    "moduleResolution": "Node16",
    "lib":              ["ES2022"],
    "outDir":           "dist",
    "rootDir":          ".",
    "strict":           true,
    "esModuleInterop":  true,
    "skipLibCheck":     true,
    "resolveJsonModule": true,
    "sourceMap":        true,
    "isolatedModules":  true,
    "types":            ["@cap-js/cds-types", "node", "jest"]
  },
  "include": ["srv/**/*", "db/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist", "gen"]
}
