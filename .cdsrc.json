{
  "requires": {
    "db": {
      "[production]": {
        "kind": "hana",
        "deploy-format": "hdbtable"
      },
      "[development]": {
        "kind": "sqlite",
        "credentials": { "database": "db/dev.db" }
      },
      "[test]": {
        "kind": "sqlite",
        "credentials": { "database": ":memory:" }
      }
    }
  },
  "features": {
    "typescript": true
  }
}
