# SAP AI Core (OAuth2 Client Credentials)
AICORE_AUTH_URL=https://<subdomain>.authentication.<region>.hana.ondemand.com/oauth/token
AICORE_CLIENT_ID=sb-<client-id>
AICORE_CLIENT_SECRET=<client-secret>
AICORE_BASE_URL=https://api.ai.prod.<region>.aws.ml.hana.ondemand.com
AICORE_RESOURCE_GROUP=default

# HANA Cloud (direct connection for vector search)
HANA_ADDRESS=<guid>.hana.trial-us10.hanacloud.ondemand.com
HANA_PORT=443
HANA_USER=<user>
HANA_PASSWORD=<password>
HANA_SCHEMA=<cds_views_schema>
HANA_SCHEMA_CUST=<custom_fields_schema>

# AI Models
CLAUDE_LLM_MODEL=anthropic--claude-4.5-sonnet
OPENAI_LLM_MODEL=gpt-4o
GEMINI_LLM_MODEL=gemini-1.5-pro
TEXT_EMBEDDING_MODEL=text-embedding-ada-002

# Processing defaults (all have code-level defaults if omitted)
CUSTOM_FIELD_THRESHOLD=0.75
MATCH_NUMBER=3
LLM_BATCH_SIZE=30
LLM_MAX_WORKERS=5
VERIFY_FLAG=false
ODATA_URL=
ODATA_USER=
ODATA_PASSWORD=
