{
  "name": "if-mapping-cap",
  "version": "0.1.0",
  "description": "SAP interface field mapping service built with CAP Node.js/TypeScript",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "cds-serve",
    "dev": "cds watch",
    "build": "cds build && tsc --noEmit",
    "codegen": "cds-typer \"*\" --outputDirectory ./@cds-models",
    "test": "jest --runInBand",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@cap-js/hana": "^1",
    "@sap/hana-client": "^2",
    "@sap-cloud-sdk/connectivity": "^4.7.0",
    "@sap-cloud-sdk/http-client": "^4.7.0",
    "@sap-cloud-sdk/resilience": "^4.7.0",
    "@sap/cds": "^8",
    "@sap/xssec": "^4",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@cap-js/cds-typer": "^0.39.1",
    "@cap-js/cds-types": "^0.11.0",
    "@sap/cds-dk": "^8",
    "@types/jest": "^29",
    "@types/node": "^20",
    "jest": "^29",
    "ts-jest": "^29",
    "typescript": "^5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tests"
    ],
    "globals": {
      "ts-jest": {
        "tsconfig": "tsconfig.test.json"
      }
    },
    "moduleNameMapper": {
      "^(\\.\\.?/.*)\\.js$": "$1"
    }
  },
  "cds": {
    "sql": {
      "native_hana_associations": false
    },
    "requires": {
      "auth": "xsuaa"
    }
  }
}
